#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRONTEND_DIR="$ROOT_DIR/webapp/stuart_frontend/stuart_app"
VENV_DIR="$ROOT_DIR/.venv"
PYTHON_BIN="$VENV_DIR/bin/python"
PIP_BIN="$VENV_DIR/bin/pip"

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required but not found on PATH. Install Python 3 first." >&2
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "npm is required but not found on PATH." >&2
  exit 1
fi

if [[ ! -f "$ROOT_DIR/requirements-stuart-v1.txt" ]]; then
  echo "Missing requirements file: $ROOT_DIR/requirements-stuart-v1.txt" >&2
  exit 1
fi

if [[ ! -d "$FRONTEND_DIR" ]]; then
  echo "Missing frontend directory: $FRONTEND_DIR" >&2
  exit 1
fi

if [[ ! -x "$PYTHON_BIN" ]]; then
  echo "[Stuart] Creating virtualenv at $VENV_DIR"
  python3 -m venv "$VENV_DIR"
fi

if [[ ! -x "$PIP_BIN" ]]; then
  echo "[Stuart] pip missing inside venv ($PIP_BIN)." >&2
  exit 1
fi

# Runtime defaults (caller env can override any of these).
: "${ASHBY_EXECUTION_PROFILE:=LOCAL_ONLY}"
: "${ASHBY_ASR_ENABLE:=1}"
: "${ASHBY_ASR_MODEL:=small}"
: "${ASHBY_ASR_DEVICE:=cpu}"
: "${ASHBY_ASR_COMPUTE_TYPE:=int8}"
: "${ASHBY_MEETINGS_LLM_ENABLED:=0}"

export ASHBY_EXECUTION_PROFILE
export ASHBY_ASR_ENABLE
export ASHBY_ASR_MODEL
export ASHBY_ASR_DEVICE
export ASHBY_ASR_COMPUTE_TYPE
export ASHBY_MEETINGS_LLM_ENABLED

echo "[Stuart] Checking Python dependency versions"
PY_DEPS_OK=1
if ! "$PYTHON_BIN" - <<'PY' "$ROOT_DIR/requirements-stuart-v1.txt"
from __future__ import annotations

import importlib.metadata as md
import sys
from pathlib import Path

try:
    from packaging.requirements import Requirement
except Exception:
    sys.exit(2)

req_file = Path(sys.argv[1])
lines = req_file.read_text(encoding="utf-8").splitlines()

for raw in lines:
    # Support inline comments in requirements lines (e.g. "pkg>=x  # note")
    line = raw.split("#", 1)[0].strip()
    if not line or line.startswith("#"):
        continue
    if line.startswith(("-r", "--", "git+", "http://", "https://", "file:")):
        # requirements-stuart-v1.txt currently uses direct package specs; skip unsupported forms.
        continue
    try:
        req = Requirement(line)
    except Exception:
        print(f"UNPARSEABLE_REQUIREMENT::{line}")
        sys.exit(1)
    try:
        installed = md.version(req.name)
    except md.PackageNotFoundError:
        print(f"MISSING::{req.name}")
        sys.exit(1)
    if req.specifier and installed not in req.specifier:
        print(f"VERSION_MISMATCH::{req.name}::{installed}::expected {req.specifier}")
        sys.exit(1)

sys.exit(0)
PY
then
  PY_DEPS_OK=0
fi

if [[ "$PY_DEPS_OK" -ne 1 ]]; then
  echo "[Stuart] Installing/updating Python dependencies"
  "$PIP_BIN" install --upgrade pip
  "$PIP_BIN" install -r "$ROOT_DIR/requirements-stuart-v1.txt"
else
  echo "[Stuart] Python dependencies already satisfied"
fi

echo "[Stuart] Checking frontend dependency tree"
NPM_DEPS_OK=1
if [[ ! -d "$FRONTEND_DIR/node_modules" ]]; then
  NPM_DEPS_OK=0
else
  if ! (cd "$FRONTEND_DIR" && npm ls --depth=0 >/dev/null 2>&1); then
    NPM_DEPS_OK=0
  fi
fi

if [[ "$NPM_DEPS_OK" -ne 1 ]]; then
  echo "[Stuart] Installing/updating frontend dependencies"
  (
    cd "$FRONTEND_DIR"
    npm install
  )
else
  echo "[Stuart] Frontend dependencies already satisfied"
fi

echo "[Stuart] Booting Stuart stack"
exec "$ROOT_DIR/scripts/stuart_up.sh"
